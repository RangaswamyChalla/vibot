# VoiceBot AXIOM - Production Configuration Example

# Security
VOICEBOT_API_KEY=axiom-dev-key
# Allowed origins for CORS (e.g. http://localhost:8501)
CORS_ALLOWED_ORIGINS=http://localhost:8501

# Braing Engine (axiom or legacy)
# axiom uses local Ollama, legacy uses OpenAI
DEFAULT_LLM_ENGINE=axiom
USE_LEGACY_OPENAI=false

# Ollama (Local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text

# OpenAI (Fallback)
OPENAI_API_KEY=your_openai_key_here

# Performance
KEEP_MODELS_IN_MEMORY=true
QUEUE_SIZE=100
WORKER_COUNT=4

# Storage
CONVERSATION_DIR=conversations
RAG_PERSIST_DIR=data/chroma_db
QUEUE_PERSIST_PATH=data/queue_state.json

# Vision
VISION_MODEL=llava
MAX_UPLOAD_SIZE_MB=10
